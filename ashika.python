```python
def selection_sort_optimized(arr):
    n = len(arr)
    for i in range(n - 1):  # Updated to iterate until n-1
        min_index = i

        for j in range(i, n):
            if arr[j] < arr[min_index]:
                min_index = j

        if min_index != i:
            arr[i], arr[min_index] = arr[min_index], arr[i]

    return arr
```